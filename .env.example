# Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # Generate a secret key: `pnpm dlx @better-auth/cli secret`

# SQLite database path for Better Auth. Defaults to ./dev-auth.db when unset.
# Use ":memory:" for an ephemeral database (e.g. isolated e2e test runs).
# AUTH_DB_PATH=./dev-auth.db

# Base URL for the Playwright e2e preview server (a separate `vp preview`
# instance from the one BETTER_AUTH_URL points at, so it needs its own port).
E2E_BASE_URL=http://localhost:3100
